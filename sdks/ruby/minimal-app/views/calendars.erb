<% @title = 'Calendars' %>
<h1>Calendars</h1>
<% if @error %>
  <div class="alert alert-error"><%= h(@error) %></div>
<% end %>
<div class="events-table-wrap">
  <table>
    <thead>
      <tr><th>Provider</th><th>Title</th><th>ID</th><th>Timezone</th><th></th></tr>
    </thead>
    <tbody>
      <% if @calendars.empty? %>
        <tr><td colspan="5" style="text-align:center;color:#6b7280;padding:2rem">No calendars found.</td></tr>
      <% else %>
        <% @calendars.each do |cal| %>
          <tr>
            <td><span class="provider-badge provider-<%= h(cal.provider) %>"><%= h(cal.provider) %></span></td>
            <td class="event-title"><%= h(cal.title) %></td>
            <td><code style="font-size:.75rem"><%= h(cal.id) %></code></td>
            <td><%= h(cal.time_zone) %></td>
            <td><a href="/event-edit?calendarId=<%= Rack::Utils.escape(cal.id) %>&provider=<%= Rack::Utils.escape(cal.provider.to_s) %>">create event</a></td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>
