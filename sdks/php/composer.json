{
  "name": "mobiscroll/connect-php",
  "description": "PHP SDK for Mobiscroll Connect API",
  "type": "library",
  "license": "ISC",
  "authors": [
    {
      "name": "Mobiscroll",
      "email": "support@mobiscroll.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "guzzlehttp/guzzle": "^7.5",
    "guzzlehttp/promises": "^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "mockery/mockery": "^1.6",
    "phpstan/phpstan": "^1.10"
  },
  "autoload": {
    "psr-4": {
      "Mobiscroll\\Connect\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Mobiscroll\\Connect\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:watch": "phpunit --watch",
    "stan": "phpstan analyse src",
    "lint": "phpstan analyse src tests --level=8"
  },
  "minimum-stability": "stable",
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "phpunit/phpunit": true
    }
  }
}
