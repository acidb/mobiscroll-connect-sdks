# REQUIRED: Real Mobiscroll OAuth credentials from your app settings
# Get these from: https://admin.mobiscroll.com/apps
# These are EXAMPLES - replace with your real values!
MOBISCROLL_CLIENT_ID=your-real-client-id-here
MOBISCROLL_CLIENT_SECRET=your-real-client-secret-here

# OAuth redirect URI must match your app's registered redirect URI
MOBISCROLL_REDIRECT_URI=http://localhost:8080/?action=callback

# Test user ID for OAuth flow
MOBISCROLL_USER_ID=test-user-123

# Calendar provider to test: google, microsoft, apple, caldav
MOBISCROLL_PROVIDER=google, microsoft, apple, caldav
