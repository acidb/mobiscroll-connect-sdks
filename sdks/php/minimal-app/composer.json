{
  "name": "mobiscroll/connect-php-minimal-app",
  "description": "Minimal app for testing mobiscroll/connect-php SDK locally",
  "type": "project",
  "require": {
    "php": "^8.1",
    "mobiscroll/connect-php": "*"
  },
  "repositories": [
    {
      "type": "path",
      "url": "..",
